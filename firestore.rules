rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Match any document in the 'users' collection
    match /users/{userId} {
      // Allow read/write only if the user is authenticated and their uid matches the document ID
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow the same rules for any subcollections under the user's document
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
